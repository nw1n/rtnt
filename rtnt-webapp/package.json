{
  "name": "rtnt-webapp",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "generate-env": "node scripts/generate-env.js",
    "start": "npm run generate-env && ng serve",
    "build": "npm run generate-env && ng build",
    "watch": "npm run generate-env && ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "format": "prettier --write \"src/**/*.{ts,js,json,css,scss,html}\""
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "^21.2.2",
    "@angular/common": "^21.2.4",
    "@angular/compiler": "^21.2.4",
    "@angular/core": "^21.2.4",
    "@angular/forms": "^21.2.4",
    "@angular/material": "^21.2.2",
    "@angular/platform-browser": "^21.2.4",
    "@angular/router": "^21.2.4",
    "@elderbyte/ngx-starter": "^21.5.0",
    "@elderbyte/ts-logger": "^0.1.2",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.2",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.2.4",
    "@elderbyte/code-style": "^5.3.0",
    "typescript": "~5.9.2"
  }
}
